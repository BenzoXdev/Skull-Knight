# Skull Knight Client Environment Configuration
# Copy this file to .env or set as environment variables

# Server URL - MUST use wss:// (TLS is always enabled on server)
Skull Knight_SERVER=wss://your-server.com:5173

# TLS Configuration
# For development with self-signed certificates:
# Skull Knight_TLS_INSECURE_SKIP_VERIFY=true

# For production, trust the server certificate (copy server.crt from server):
# Skull Knight_TLS_CA=./certs/server.crt
Skull Knight_TLS_INSECURE_SKIP_VERIFY=false

# Client certificate for mutual TLS (optional, advanced)
# Skull Knight_TLS_CLIENT_CERT=./certs/client.crt
# Skull Knight_TLS_CLIENT_KEY=./certs/client.key

# Mutex (single-instance) configuration
# Leave empty or set to "none" to allow multiple instances
# Skull Knight_MUTEX=Skull Knight-client

# Capture Configuration
Skull Knight_CAPTURE_INTERVAL=20s
Skull Knight_DISABLE_CAPTURE=false

# Mode: dev, development, local, release, prod, production
Skull Knight_MODE=production
